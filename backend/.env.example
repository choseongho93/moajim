# ── Python 백엔드 환경변수 ──
# 단일 Postgres (provider 무관: Supabase/Neon/Fly Postgres 등). asyncpg 드라이버 사용.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/moajim

# 국토교통부 실거래가 OpenAPI 서비스키 (공공데이터포털). 운영에선 secret으로 관리 권장.
GOV_DATA_API_KEY=3f1f2c2bf9045370f2a379a9f3ff2d1af1fa91cefb44635549ce5a663a66c1d3

# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=https://moajim.com,http://localhost:5173

# 해외 차단: 허용 국가 (CF-IPCountry 기준, 콤마 구분). T1=Tor
ALLOWED_COUNTRIES=KR,T1
ENFORCE_GEO=true

# 시작 시 migrations/*.sql 자동 적용 여부 (운영은 false 권장, psql로 수동 적용)
AUTO_MIGRATE=false

ENVIRONMENT=development
